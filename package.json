{
  "name": "tp-connect",
  "version": "0.1.0",
  "description": "Open one or more database URLs from .env in TablePlus.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "tp-connect": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/cli.js",
